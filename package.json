{
  "name": "away-timer",
  "version": "1.1.3",
  "description": "A minimal dark-themed desktop timer with away-time tracking for productivity",
  "main": "dist-electron/main.js",
  "author": "Away Timer",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "posthog-node": "^5.38.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.awaytimer.app",
    "productName": "Away Timer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "build/license.txt",
      "shortcutName": "Away Timer"
    },
    "publish": {
      "provider": "github",
      "owner": "mxw6767-coder",
      "repo": "away-timer"
    }
  }
}
